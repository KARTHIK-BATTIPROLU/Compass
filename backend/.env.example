# Environment Variables
# Copy to .env and fill in values

# MongoDB — local default or Atlas connection string
# Local: mongodb://localhost:27017/edtech
# Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/edtech?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/edtech

JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Required from Phase 2+
GROQ_API_KEY=
GEMINI_API_KEY=

# CORS
FRONTEND_ORIGIN=http://localhost:5173
